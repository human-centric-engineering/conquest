// ConQuest questionnaire app schema.
//
// App-owned models (App… prefix, snake_case @@map). Kept in a dedicated file —
// the platform's app.prisma already holds platform models, so the questionnaire
// schema stays separate and conflict-free on upstream syncs.
//
// F0.1 lays down only the anchor (AppQuestionnaire + AppQuestionnaireVersion).
// Later phases extend this graph (ingestion P1, config/invitations P3, sessions
// P4, evaluation P5, turns P6). See .context/app/questionnaire/schema.md.
//
// User FKs are deferred: the plain-String-User-FK recipe creates a
// Prisma-unmodelled object with real maintenance cost (see upstream-gaps UG-1).
// Nothing here needs user ownership yet, so these models use only app-internal
// @relation (onDelete: Cascade) — fully modelled, clean drift.

/// The top-level container an admin authors, configures, and launches.
model AppQuestionnaire {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("draft")
  // DEMO-ONLY (F2.5.1): which demo client this questionnaire is attributed to.
  // null = "Generic Sunrise demo" (defaults end-to-end); no backfill on older rows.
  // SetNull, not Cascade: a questionnaire outlives its demo client — attribution
  // just clears. The admin DELETE refuses (409) while attributed, so this is the
  // schema-honest backstop, not the happy path. See .context/app/questionnaire/demo-clients.md.
  demoClientId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  versions   AppQuestionnaireVersion[]
  demoClient AppDemoClient?            @relation(fields: [demoClientId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([demoClientId])
  @@map("app_questionnaire")
}

/// A version of a questionnaire. Edits to a launched version fork a new draft
/// version (P2); in-flight sessions stay pinned to the version they began on.
///
/// `goal`/`audience` live on the VERSION (not AppQuestionnaire): the versioning
/// model pins them where launch (F3.1) and evaluation (F5 judges) operate. Both
/// are inferred by the F1.1 extractor (recorded as infer_goal / infer_audience
/// change records) or admin-set, with admin-wins-per-field merge.
model AppQuestionnaireVersion {
  id                 String   @id @default(cuid())
  questionnaireId    String
  versionNumber      Int      @default(1)
  status             String   @default("draft")
  goal               String? // inferred (infer_goal change) or admin-set
  audience           Json? // structured AudienceShape (types.ts); inferred or admin-set
  goalProvenance     String? // FieldProvenance (types.ts): admin-supplied | inferred | pre-existing
  audienceProvenance Json? // AudienceProvenance (types.ts): per-field FieldProvenance map
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  questionnaire   AppQuestionnaire                   @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  sections        AppQuestionnaireSection[]
  changeRecords   AppQuestionnaireExtractionChange[]
  sourceDocuments AppQuestionnaireSourceDocument[]
  tags            AppQuestionTag[]
  config          AppQuestionnaireConfig?
  invitations     AppQuestionnaireInvitation[]
  sessions        AppQuestionnaireSession[]

  @@unique([questionnaireId, versionNumber])
  @@index([questionnaireId])
  @@map("app_questionnaire_version")
}

/// A tokenised invitation for one respondent to complete a launched version (F3.2).
///
/// VERSION-SCOPED: the FK pins the invitation to the launched version it targets at
/// send time. A sent invitation is a launch blocker — editing a launched-with-invites
/// version forks a draft (the F2.1 seam, wired live in F3.2's route-local
/// `_lib/launch-blockers.ts`), so in-flight invitees stay on the version they were
/// invited to. New invitations always target the now-launched version. The admin
/// surface lists per-questionnaire through this relation (no `questionnaireId`
/// denormalisation); F3.4 adds the demo-client `demoClientId` denormalisation + theming.
///
/// TOKEN AT REST: `tokenHash` is the SHA-256 of the opaque token (same recipe as
/// `lib/utils/invitation-token.ts`); the plaintext lives only in the emailed URL.
/// Lookups hash the URL token and match `tokenHash`; the email is derived from the
/// row, not carried in the link.
///
/// LIFECYCLE (`status`): pending → sent → opened → registered → started → completed,
/// with `revoked` reachable from pending|sent|opened. F3.2 drives through `registered`
/// (respondent registers a real better-auth account, stamped on `userId`);
/// `started`/`completed` are seam states transitioned by P6/P7 sessions.
///
/// USER FKs are plain String, no @relation (UG-1, as `revertedByUserId`). `userId` is
/// the respondent (null until registration); `invitedByUserId` is the admin. These are
/// the first questionnaire rows referencing User — see the erasure note in
/// .context/app/questionnaire/invitations.md.
///
/// DEMO-ONLY (F3.4): `demoClientId` denormalises the attributed demo client onto the
/// invitation at send time (the route copies the questionnaire's `demoClientId` into
/// each row). This is the snapshot the themed email resolves its brand from — an O(1)
/// lookup that points at the client DIRECTLY, so later questionnaire reassignment
/// doesn't change an already-sent invitation's brand. A real @relation (onDelete:
/// SetNull, same recipe as AppQuestionnaire): deleting the client just clears the
/// snapshot and the email falls back to the Sunrise default theme.
model AppQuestionnaireInvitation {
  id              String    @id @default(cuid())
  versionId       String
  email           String // recipient address; the invitation is keyed by token, not email
  name            String? // optional recipient display name (prefills registration)
  tokenHash       String    @unique // sha256 of the opaque token; plaintext only in the email URL
  status          String    @default("pending") // APP_INVITATION_STATUSES (invitations/types.ts)
  userId          String? // respondent User.id, set on registration; plain String, no FK (UG-1)
  invitedByUserId String // admin User.id; plain String, no FK (UG-1)
  demoClientId    String? // DEMO-ONLY (F3.4): brand snapshot at send time; null = generic Sunrise theme
  expiresAt       DateTime // token expiry (INVITATION_TOKEN_EXPIRY_DAYS from now)
  sentAt          DateTime? // first successful email send
  openedAt        DateTime? // first landing-page validation of the token
  registeredAt    DateTime? // respondent bound to an account
  revokedAt       DateTime? // admin revoked
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  version    AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  demoClient AppDemoClient?          @relation(fields: [demoClientId], references: [id], onDelete: SetNull)

  @@index([versionId])
  @@index([status])
  @@index([email])
  @@index([userId])
  @@index([demoClientId])
  @@map("app_questionnaire_invitation")
}

/// The per-version run-time configuration an admin authors before launch (F3.1):
/// every knob that controls how a session runs. 1:1 with the version (`versionId`
/// unique) so it forks with the version — launch and the session runtime (P4)
/// operate on the version, not the questionnaire.
///
/// LAZY: no row exists until the admin first saves config. The read path resolves
/// an absent row to DEFAULT_QUESTIONNAIRE_CONFIG (types.ts), so a never-configured
/// version still renders complete defaults; the launch gate (F3.1) treats "config
/// saved at least once" (a row exists) as the deliberate readiness signal. The
/// fork writer copies this row into the new draft only when present.
///
/// `profileFields` is the ordered list of session-start profile fields the admin
/// collects (name/email/role/custom), stored as JSON (ProfileFieldConfig[] in
/// types.ts) — a small admin-authored list read wholesale at session start, not
/// queried field-by-field, so it needs no relational model. No User FK (UG-1).
model AppQuestionnaireConfig {
  id        String @id @default(cuid())
  versionId String @unique

  // Question selection (F4.1): how the agent picks the next question.
  selectionStrategy String @default("sequential") // sequential | random | weighted | adaptive (SELECTION_STRATEGIES)

  // Completion thresholds: when a session may be considered done.
  minQuestionsAnswered Int   @default(0) // require at least this many answered
  coverageThreshold    Float @default(1.0) // 0–1 fraction of (weighted) questions covered

  // Budget & caps (F3.3/F6.3 consume these; F3.1 only stores them).
  costBudgetUsd          Float? // per-session USD cap; null = no cap
  maxQuestionsPerSession Int? // hard question cap; null = no cap

  // Modes.
  voiceEnabled         Boolean @default(false) // allow voice input (F6.2)
  contradictionMode    String  @default("off") // off | flag | probe (CONTRADICTION_MODES)
  contradictionWindowN Int     @default(0) // N prior answers to check against; 0 when mode=off
  anonymousMode        Boolean @default(false) // don't collect identifying profile fields

  // Session-start profile fields (ProfileFieldConfig[] — types.ts).
  profileFields Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@map("app_questionnaire_config")
}

/// A section/group within a version. Plain entity — extraction provenance
/// (sourceQuote, rationale, confidence) lives on the CHANGE RECORDS, not here.
model AppQuestionnaireSection {
  id          String   @id @default(cuid())
  versionId   String
  ordinal     Int
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  version   AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  questions AppQuestionSlot[]

  @@index([versionId])
  @@map("app_questionnaire_section")
}

/// A single question. `type` vocabulary is the project-canonical set from the
/// deep spec. `key` is a stable per-version slug (answers/re-ingest reference it,
/// not the cuid). `weight` feeds F4.1 weighted selection.
///
/// ⚠️ PRISMA-SCHEMA DRIFT WARNING ⚠️
/// `embedding` is a pgvector column (F4.1 adaptive selection). Two Postgres
/// objects on it are managed via raw SQL in migrations because Prisma cannot
/// model them natively:
///   1. The `vector(1536)` column type — modelled as `Unsupported(...)` so Prisma
///      creates the column, but it stays absent from typed selects (read/written
///      via $queryRawUnsafe / $executeRawUnsafe in `_lib/slot-embeddings.ts`).
///   2. The HNSW ANN index `idx_app_question_slot_embedding`
///      (vector_cosine_ops, m=16, ef_construction=64) — added by raw SQL in the
///      F4.1 migration.
/// `npx prisma migrate dev` may try to DROP the index on a schema-diff run; always
/// inspect generated SQL and remove any line touching
/// `idx_app_question_slot_embedding` before applying (the same discipline the
/// knowledge `embedding` column documents).
model AppQuestionSlot {
  id                   String   @id @default(cuid())
  versionId            String // denormalised — F2.2 tagging validates tag+slot share a version
  sectionId            String
  ordinal              Int
  key                  String // slug, unique per version
  prompt               String
  guidelines           String?
  rationale            String?
  type                 String   @default("free_text") // free_text|single_choice|multi_choice|likert|numeric|date|boolean
  typeConfig           Json? // choices, likert bounds, etc.
  required             Boolean  @default(false)
  weight               Float    @default(1.0)
  extractionConfidence Float? // 0–1, set by the extractor
  // F4.1 adaptive selection: cosine-similarity vector over `prompt` (+`guidelines`).
  // Width matches the platform embedding model (AiKnowledgeChunk.embedding). Raw-SQL
  // read/write only — see the drift warning above.
  embedding            Unsupported("vector(1536)")?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  section AppQuestionnaireSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  tags    AppQuestionSlotTag[]
  answers AppAnswerSlot[]

  @@unique([versionId, key])
  @@index([versionId])
  @@index([sectionId])
  @@map("app_question_slot")
}

/// A tag in a version's vocabulary (F2.2). Version-scoped — the vocabulary forks
/// with the version. `normalizedLabel` (trim+lowercase of `label`) is the
/// case-insensitive dedup key; `color` is an optional UI/analytics swatch.
/// Assigned to questions via the AppQuestionSlotTag join. Consumed by P8 analytics
/// filtering and F4.1 adaptive selection.
model AppQuestionTag {
  id              String   @id @default(cuid())
  versionId       String
  label           String
  normalizedLabel String // trim+lowercase of label; case-insensitive uniqueness key
  color           String? // optional swatch from the TAG_COLORS allowlist (types.ts)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  slots   AppQuestionSlotTag[]

  @@unique([versionId, normalizedLabel])
  @@index([versionId])
  @@map("app_question_tag")
}

/// M:N assignment of a vocabulary tag to a question (F2.2). Both sides cascade.
/// Application-layer validation (not a DB constraint) enforces that the tag and
/// slot belong to the same version — `AppQuestionSlot.versionId` is denormalised
/// for exactly this check.
model AppQuestionSlotTag {
  id             String   @id @default(cuid())
  questionSlotId String
  tagId          String
  createdAt      DateTime @default(now())

  questionSlot AppQuestionSlot @relation(fields: [questionSlotId], references: [id], onDelete: Cascade)
  tag          AppQuestionTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([questionSlotId, tagId])
  @@index([questionSlotId])
  @@index([tagId])
  @@map("app_question_slot_tag")
}

/// The revertible audit trail of every editorial decision the extractor made,
/// LLM-self-reported at extraction time. F2.3 lists these and restores `beforeJson`
/// on revert. Write path supports the full vocabulary; F1.1 EMITS the editorial +
/// inference set (prune, correct, rewrite_prompt, infer_type, merge_questions,
/// split_question, add_section, augment_question, infer_goal, infer_audience).
model AppQuestionnaireExtractionChange {
  id               String    @id @default(cuid())
  versionId        String
  changeType       String // see vocabulary note in ingestion docs
  targetEntityType String // section | question | version
  targetEntityId   String? // null for pruned-never-persisted / version-level
  sourceQuote      String? // the span in the source document
  beforeJson       Json? // pre-change state; restored on revert (null for creations)
  afterJson        Json? // post-change state (null for prune_*)
  rationale        String?
  confidence       Float?
  status           String    @default("applied") // applied | reverted
  revertedAt       DateTime? // set in F2.3
  revertedByUserId String? // plain String, no FK (UG-1); set in F2.3
  createdAt        DateTime  @default(now())

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId, status])
  @@index([changeType])
  @@map("app_questionnaire_extraction_change")
}

/// The uploaded source doc — supports SHA-256 dedup (F2.4 re-ingest) and parse
/// provenance / source-quote verification. NO User FK (UG-1).
model AppQuestionnaireSourceDocument {
  id            String   @id @default(cuid())
  versionId     String
  fileName      String
  fileHash      String // sha256 of the raw bytes
  byteSize      Int
  mimeType      String?
  pageCount     Int?
  warnings      Json? // parsed.warnings[]
  extractedText String   @db.Text // what extraction consumed; F2.3 verifies source quotes against it
  bytes         Bytes? // OPTIONAL raw upload, for F2.4 diff-against-source/re-parse with new opts
  createdAt     DateTime @default(now())

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([fileHash])
  @@map("app_questionnaire_source_document")
}

/// DEMO-ONLY (F2.5.1): demo-tenancy attribution + branding partition, NOT a
/// security boundary. Lets a questionnaire be labelled as a given prospect's demo
/// so the sales surface is attributable. Application-layer scoping on
/// single-tenant Sunrise — demo clients aren't adversarial, so hard isolation is
/// out of scope. A multi-customer fork activates Sunrise's RLS seam
/// (`TENANCY_MODE=multi`, `Org`/`orgId` at `lib/db/client.ts`) rather than
/// hardening this table.
///
/// FORK-GUIDANCE: see .context/app/questionnaire/forking.md § "Replacing demo
/// tenancy" — delete entirely (single-tenant prod) · rename to AppTenant + RLS
/// (multi-tenant prod) · keep as AppBrand without the marker.
///
/// IDENTITY + THEME. F2.5.1 landed identity only; F3.4 adds the theme columns now
/// that they have their first renderer (the invitation email; the F7.1 user UI is
/// the second). All theme columns are NULLABLE — `resolveTheme()`
/// (lib/app/questionnaire/theming) fills nulls with Sunrise defaults, so an
/// unthemed client renders exactly as before. The reset-sessions and
/// clone-for-client utilities still land in F6.4 / P3+. No User FK (UG-1) — a
/// global admin-managed fixture table, ownership implicit.
model AppDemoClient {
  id          String   @id @default(cuid())
  slug        String   @unique // URL-safe ("acme-bank"); admin URLs + later invite links
  name        String // display name ("Acme Bank Demo")
  description String? // internal admin note ("Prepared for the Q1 2026 pitch")
  isActive    Boolean  @default(true) // soft-disable without delete

  // DEMO-ONLY (F3.4): theme columns. All nullable — null means "use the Sunrise
  // default" (resolveTheme fills it). The invitation email reads all four (ctaColor =
  // button, accentColor = fallback-link colour, logoUrl = header image, welcomeCopy =
  // intro line); accentColor is ALSO the F7.1 CSS accent variable.
  ctaColor    String? // CTA / primary button colour (hex, e.g. "#5469d4")
  accentColor String? // secondary accent colour (hex); email fallback-link colour + F7.1 CSS var
  logoUrl     String? // absolute https URL of the client logo shown in the email header
  welcomeCopy String? // branded intro line for the invitation email body

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Reverse relation (F2.5.1 AD2): the list endpoint counts attributed
  // questionnaires per client and the DELETE 409-guard reads it directly.
  questionnaires AppQuestionnaire[]
  // DEMO-ONLY (F3.4): invitations carrying this client's brand snapshot. SetNull on
  // delete (see AppQuestionnaireInvitation); the 409-guard counts questionnaires, not
  // these, so deleting a client clears its sent invitations' brand to the default.
  invitations AppQuestionnaireInvitation[]

  @@map("app_demo_client")
}

/// A respondent's run over one launched version — the minimal slice of F4.6's
/// session machinery that F4.4 introduces to anchor persisted answers. The full
/// session/turn lifecycle (turn tables, profile snapshot, resumption) lands in
/// F4.6; this carries only what answer rows need: which version, a status, and an
/// optional respondent.
///
/// `isPreview` distinguishes a session created by the admin refine-answer route
/// (which exercises the write path before real respondent sessions exist) from a
/// genuine respondent run, so P8 analytics can exclude preview rows. The route
/// reuses one preview session per version (idempotent), so admins don't accrete
/// throwaway sessions.
///
/// `respondentUserId` is a plain String, no @relation (UG-1, as on
/// AppQuestionnaireInvitation); null until F4.6 binds real respondent sessions.
model AppQuestionnaireSession {
  id               String   @id @default(cuid())
  versionId        String
  status           String   @default("active") // SESSION_STATUSES (types.ts): active | completed | abandoned
  isPreview        Boolean  @default(false) // true = admin refine-answer exercise, not a respondent run
  respondentUserId String? // respondent User.id; plain String, no FK (UG-1); set in F4.6
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  answers AppAnswerSlot[]

  @@index([versionId])
  @@index([versionId, isPreview])
  // DRIFT WARNING: a raw-SQL PARTIAL UNIQUE INDEX
  // (idx_app_questionnaire_session_preview_per_version, migration
  // 20260605141500) enforces at most one preview session per version
  // (WHERE "isPreview" = true) — Prisma can't model partial uniques, so it's
  // invisible here and a `migrate dev` schema-diff would emit a phantom DROP.
  // A drift probe in lib/app/db-drift.ts guards it; getOrCreatePreviewSession
  // (F4.5) depends on it for race-safety. Author future migrations on this
  // table with `--create-only` and strip any DROP of that index.
  @@map("app_questionnaire_session")
}

/// One captured answer for a question slot within a session. F4.2 produces the
/// extraction INTENTS; F4.4 is the first writer (via the refine-answer route) and
/// owns the refinement update: the value/provenance change plus an appended
/// `refinementHistory` entry. F4.6 wires the live per-turn write path on top of the
/// same model.
///
/// `provenanceLabel` is a plain String validated against ANSWER_PROVENANCES at the
/// boundary (house style — `selectionStrategy`/`contradictionMode` are columns, not
/// Prisma enums), so adding a label is a tuple edit, not a migration. A `refine`
/// transitions it to `refined`; an `overwrite` preserves it.
///
/// `confidence` is a Float 0–1 (matching AppQuestionSlot.extractionConfidence), NOT
/// the Int(1–10) an early spec sketched. `refinementHistory` is a JSON array of
/// RefinementHistoryEntry (refinement/types.ts), default []. `provenanceItems` holds
/// Sunrise's ProvenanceItem[] contract for PII/cost; F4.4 does not populate it.
model AppAnswerSlot {
  id                String   @id @default(cuid())
  sessionId         String
  questionSlotId    String
  value             Json
  confidence        Float? // 0–1; null when not scored
  provenanceLabel   String   @default("direct") // ANSWER_PROVENANCES (types.ts)
  provenanceItems   Json? // Sunrise ProvenanceItem[]; reserved, not populated by F4.4
  rationale         String?
  lastUpdatedTurnId String? // F4.6 turn-loop seam; null until the live loop exists
  refinementHistory Json     @default("[]") // RefinementHistoryEntry[] (refinement/types.ts)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  session      AppQuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionSlot AppQuestionSlot         @relation(fields: [questionSlotId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionSlotId]) // one answer per slot per session — the upsert key
  @@index([sessionId])
  @@index([questionSlotId])
  @@map("app_answer_slot")
}
