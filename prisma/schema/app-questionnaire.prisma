// ConQuest questionnaire app schema.
//
// App-owned models (App… prefix, snake_case @@map). Kept in a dedicated file —
// the platform's app.prisma already holds platform models, so the questionnaire
// schema stays separate and conflict-free on upstream syncs.
//
// F0.1 lays down only the anchor (AppQuestionnaire + AppQuestionnaireVersion).
// Later phases extend this graph (ingestion P1, config/invitations P3, sessions
// P4, evaluation P5, turns P6). See .context/app/questionnaire/schema.md.
//
// User FKs are deferred: the plain-String-User-FK recipe creates a
// Prisma-unmodelled object with real maintenance cost (see upstream-gaps UG-1).
// Nothing here needs user ownership yet, so these models use only app-internal
// @relation (onDelete: Cascade) — fully modelled, clean drift.

/// The top-level container an admin authors, configures, and launches.
model AppQuestionnaire {
  id           String   @id @default(cuid())
  title        String
  status       String   @default("draft")
  // DEMO-ONLY (F2.5.1): which demo client this questionnaire is attributed to.
  // null = "Generic Sunrise demo" (defaults end-to-end); no backfill on older rows.
  // SetNull, not Cascade: a questionnaire outlives its demo client — attribution
  // just clears. The admin DELETE refuses (409) while attributed, so this is the
  // schema-honest backstop, not the happy path. See .context/app/questionnaire/demo-clients.md.
  demoClientId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  versions   AppQuestionnaireVersion[]
  demoClient AppDemoClient?            @relation(fields: [demoClientId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([demoClientId])
  @@map("app_questionnaire")
}

/// A version of a questionnaire. Edits to a launched version fork a new draft
/// version (P2); in-flight sessions stay pinned to the version they began on.
///
/// `goal`/`audience` live on the VERSION (not AppQuestionnaire): the versioning
/// model pins them where launch (F3.1) and evaluation (F5 judges) operate. Both
/// are inferred by the F1.1 extractor (recorded as infer_goal / infer_audience
/// change records) or admin-set, with admin-wins-per-field merge.
model AppQuestionnaireVersion {
  id                 String   @id @default(cuid())
  questionnaireId    String
  versionNumber      Int      @default(1)
  status             String   @default("draft")
  goal               String? // inferred (infer_goal change) or admin-set
  audience           Json? // structured AudienceShape (types.ts); inferred or admin-set
  goalProvenance     String? // FieldProvenance (types.ts): admin-supplied | inferred | pre-existing
  audienceProvenance Json? // AudienceProvenance (types.ts): per-field FieldProvenance map
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  questionnaire   AppQuestionnaire                   @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  sections        AppQuestionnaireSection[]
  changeRecords   AppQuestionnaireExtractionChange[]
  sourceDocuments AppQuestionnaireSourceDocument[]
  tags            AppQuestionTag[]
  config          AppQuestionnaireConfig?
  invitations     AppQuestionnaireInvitation[]
  sessions        AppQuestionnaireSession[]
  evaluationRuns  AppQuestionnaireEvaluationRun[]
  dataSlots       AppDataSlot[]
  dataSlotDraft   AppDataSlotDraft?

  @@unique([questionnaireId, versionNumber])
  @@index([questionnaireId])
  @@map("app_questionnaire_version")
}

/// A tokenised invitation for one respondent to complete a launched version (F3.2).
///
/// VERSION-SCOPED: the FK pins the invitation to the launched version it targets at
/// send time. A sent invitation is a launch blocker — editing a launched-with-invites
/// version forks a draft (the F2.1 seam, wired live in F3.2's route-local
/// `_lib/launch-blockers.ts`), so in-flight invitees stay on the version they were
/// invited to. New invitations always target the now-launched version. The admin
/// surface lists per-questionnaire through this relation (no `questionnaireId`
/// denormalisation); F3.4 adds the demo-client `demoClientId` denormalisation + theming.
///
/// TOKEN AT REST: `tokenHash` is the SHA-256 of the opaque token (same recipe as
/// `lib/utils/invitation-token.ts`); the plaintext lives only in the emailed URL.
/// Lookups hash the URL token and match `tokenHash`; the email is derived from the
/// row, not carried in the link.
///
/// LIFECYCLE (`status`): pending → sent → opened → registered → started → completed,
/// with `revoked` reachable from pending|sent|opened. F3.2 drives through `registered`
/// (respondent registers a real better-auth account, stamped on `userId`);
/// `started`/`completed` are seam states transitioned by P6/P7 sessions.
///
/// USER FKs are plain String, no @relation (UG-1, as `revertedByUserId`). `userId` is
/// the respondent (null until registration); `invitedByUserId` is the admin. These are
/// the first questionnaire rows referencing User — see the erasure note in
/// .context/app/questionnaire/invitations.md.
///
/// DEMO-ONLY (F3.4): `demoClientId` denormalises the attributed demo client onto the
/// invitation at send time (the route copies the questionnaire's `demoClientId` into
/// each row). This is the snapshot the themed email resolves its brand from — an O(1)
/// lookup that points at the client DIRECTLY, so later questionnaire reassignment
/// doesn't change an already-sent invitation's brand. A real @relation (onDelete:
/// SetNull, same recipe as AppQuestionnaire): deleting the client just clears the
/// snapshot and the email falls back to the Sunrise default theme.
model AppQuestionnaireInvitation {
  id              String    @id @default(cuid())
  versionId       String
  email           String // recipient address; the invitation is keyed by token, not email
  name            String? // optional recipient display name (prefills registration)
  profile         Json? // InviteeProfile — captured per-invitee detail fields (firstName, jobTitle, …) per config.inviteeFields; email/name stay as columns
  tokenHash       String    @unique // sha256 of the opaque token; plaintext only in the email URL
  status          String    @default("pending") // APP_INVITATION_STATUSES (invitations/types.ts)
  userId          String? // respondent User.id, set on registration; plain String, no FK (UG-1)
  invitedByUserId String // admin User.id; plain String, no FK (UG-1)
  demoClientId    String? // DEMO-ONLY (F3.4): brand snapshot at send time; null = generic Sunrise theme
  expiresAt       DateTime // token expiry (INVITATION_TOKEN_EXPIRY_DAYS from now)
  sentAt          DateTime? // first successful email send
  openedAt        DateTime? // first landing-page validation of the token
  registeredAt    DateTime? // respondent bound to an account
  revokedAt       DateTime? // admin revoked
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  version    AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  demoClient AppDemoClient?          @relation(fields: [demoClientId], references: [id], onDelete: SetNull)

  @@index([versionId])
  @@index([status])
  @@index([email])
  @@index([userId])
  @@index([demoClientId])
  @@map("app_questionnaire_invitation")
}

/// The per-version run-time configuration an admin authors before launch (F3.1):
/// every knob that controls how a session runs. 1:1 with the version (`versionId`
/// unique) so it forks with the version — launch and the session runtime (P4)
/// operate on the version, not the questionnaire.
///
/// LAZY: no row exists until the admin first saves config. The read path resolves
/// an absent row to DEFAULT_QUESTIONNAIRE_CONFIG (types.ts), so a never-configured
/// version still renders complete defaults; the launch gate (F3.1) treats "config
/// saved at least once" (a row exists) as the deliberate readiness signal. The
/// fork writer copies this row into the new draft only when present.
///
/// `profileFields` is the ordered list of session-start profile fields the admin
/// collects (name/email/role/custom), stored as JSON (ProfileFieldConfig[] in
/// types.ts) — a small admin-authored list read wholesale at session start, not
/// queried field-by-field, so it needs no relational model. No User FK (UG-1).
model AppQuestionnaireConfig {
  id        String @id @default(cuid())
  versionId String @unique

  // Question selection (F4.1): how the agent picks the next question.
  selectionStrategy String @default("sequential") // sequential | random | weighted | adaptive (SELECTION_STRATEGIES)

  // Completion thresholds: when a session may be considered done.
  minQuestionsAnswered Int   @default(0) // require at least this many answered
  coverageThreshold    Float @default(1.0) // 0–1 fraction of (weighted) questions covered

  // Budget & caps (F3.3/F6.3 consume these; F3.1 only stores them).
  costBudgetUsd          Float? // per-session USD cap; null = no cap
  maxQuestionsPerSession Int? // hard question cap; null = no cap

  // Modes.
  voiceEnabled             Boolean @default(false) // allow voice input (F6.2)
  attachmentsEnabled       Boolean @default(false) // allow respondent file attachments (paperclip); gated also by the platform attachment-input flag
  contradictionMode        String  @default("off") // off | flag | probe (CONTRADICTION_MODES)
  contradictionWindowN     Int     @default(0) // N prior answers to check against; 0 when mode=off
  contradictionEveryNTurns Int     @default(1) // run detection every N respondent turns; 1 = every turn
  answerFitMode            String  @default("fallback") // off | fallback | always (ANSWER_FIT_MODES) — semantic free-form → choice/likert resolver pass
  anonymousMode            Boolean @default(false) // don't collect identifying profile fields (IDENTITY axis)
  accessMode               String  @default("invitation_only") // invitation_only | public | both (ACCESS_MODES) — who may START (access axis, orthogonal to anonymousMode)
  inviteeFields            Json    @default("[{\"key\":\"firstName\",\"shown\":true,\"required\":false},{\"key\":\"surname\",\"shown\":true,\"required\":false},{\"key\":\"email\",\"shown\":true,\"required\":true},{\"key\":\"jobTitle\",\"shown\":false,\"required\":false},{\"key\":\"team\",\"shown\":false,\"required\":false},{\"key\":\"organisation\",\"shown\":false,\"required\":false}]") // InviteeFieldConfig[] — per-invitee detail fields the admin captures (email forced on)

  // Seriousness / abuse gate: how many non-genuine (preposterous / abusive / off-topic)
  // answers a session tolerates before it is abandoned. 0 = off for this questionnaire.
  // Escalating warnings precede the abandon strike. Globally gated by the platform flag
  // APP_QUESTIONNAIRES_SERIOUSNESS_GATE_ENABLED — inert until the operator turns it on.
  abuseThreshold Int @default(4)

  // Data Slots feature: how many times a data slot is targeted before the agent records a
  // best-effort provisional fill and moves on. 2 = ask once, re-ask once specifically, then park.
  maxDataSlotAttempts Int @default(2)

  // Sensitivity awareness / safeguarding: when on (AND the platform flag
  // APP_QUESTIONNAIRES_SENSITIVITY_AWARENESS_ENABLED), the agent detects + remembers a sensitive
  // disclosure and softens later phrasing. supportMessage (with optional supportResourceUrl) is
  // the verbatim copy signposted once on a serious disclosure; empty message = no signpost.
  sensitivityAwareness Boolean @default(false)
  supportMessage       String  @default("")
  supportResourceUrl   String  @default("")

  // Respondent answer-slot panel (F7.2): how much of the questionnaire the live
  // panel shows. full_progress = every slot grouped by section (X-of-N progress);
  // answered_only = just captured answers (no pending structure). (ANSWER_SLOT_PANEL_SCOPES)
  answerSlotPanelScope String @default("full_progress") // full_progress | answered_only

  // Presentation mode (P-presentation): how the respondent completes the session.
  // chat = streaming conversation (incl. data slots); form = raw sectioned form with the
  // right input per question type; both = offer both and let the respondent toggle. Default
  // chat so existing launched versions are unchanged. (PRESENTATION_MODES — types.ts)
  presentationMode String @default("chat") // chat | form | both

  // Session-start profile fields (ProfileFieldConfig[] — types.ts).
  profileFields Json @default("[]")

  // Live "watch it think" reasoning trace (demo feature): show the agent's per-turn reasoning
  // (answers captured with provenance/confidence, contradictions spotted, why the next question was
  // chosen) beside the chat. On by default; only takes effect when the platform flag
  // APP_QUESTIONNAIRES_REASONING_STREAM_ENABLED is on. placement = overlay | inline (REASONING_PLACEMENTS);
  // persist = save the trace on each turn so it replays on resume / scroll-back. (lib/.../reasoning)
  reasoningStreamEnabled   Boolean @default(true)
  reasoningStreamPlacement String  @default("overlay")
  reasoningStreamPersist   Boolean @default(true)

  // Interviewer tone & persona (F-tone): ToneSettings — nine enable-toggle + 1–5 sliders plus a
  // free-text persona, controlling HOW the conversational interviewer responds. Off per dimension
  // by default; only takes effect when the platform flag APP_QUESTIONNAIRES_TONE_ENABLED is on.
  // Fed into the phraser system prompt by buildToneInstructions (lib/.../chat/tone.ts). (types.ts)
  tone Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@map("app_questionnaire_config")
}

/// A section/group within a version. Plain entity — extraction provenance
/// (sourceQuote, rationale, confidence) lives on the CHANGE RECORDS, not here.
model AppQuestionnaireSection {
  id          String   @id @default(cuid())
  versionId   String
  ordinal     Int
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  version   AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  questions AppQuestionSlot[]

  @@index([versionId])
  @@map("app_questionnaire_section")
}

/// A single question. `type` vocabulary is the project-canonical set from the
/// deep spec. `key` is a stable per-version slug (answers/re-ingest reference it,
/// not the cuid). `weight` feeds F4.1 weighted selection.
///
/// ⚠️ PRISMA-SCHEMA DRIFT WARNING ⚠️
/// `embedding` is a pgvector column (F4.1 adaptive selection). Two Postgres
/// objects on it are managed via raw SQL in migrations because Prisma cannot
/// model them natively:
///   1. The `vector(1536)` column type — modelled as `Unsupported(...)` so Prisma
///      creates the column, but it stays absent from typed selects (read/written
///      via $queryRawUnsafe / $executeRawUnsafe in `_lib/slot-embeddings.ts`).
///   2. The HNSW ANN index `idx_app_question_slot_embedding`
///      (vector_cosine_ops, m=16, ef_construction=64) — added by raw SQL in the
///      F4.1 migration.
/// `npx prisma migrate dev` may try to DROP the index on a schema-diff run; always
/// inspect generated SQL and remove any line touching
/// `idx_app_question_slot_embedding` before applying (the same discipline the
/// knowledge `embedding` column documents).
model AppQuestionSlot {
  id                   String                       @id @default(cuid())
  versionId            String // denormalised — F2.2 tagging validates tag+slot share a version
  sectionId            String
  ordinal              Int
  key                  String // slug, unique per version
  prompt               String
  guidelines           String?
  rationale            String?
  type                 String                       @default("free_text") // free_text|single_choice|multi_choice|likert|numeric|date|boolean
  typeConfig           Json? // choices, likert bounds, etc.
  required             Boolean                      @default(false)
  weight               Float                        @default(0.5) // 0.1–1.0 slider scale; 0.5 neutral midpoint
  extractionConfidence Float? // 0–1, set by the extractor
  // F4.1 adaptive selection: cosine-similarity vector over `prompt` (+`guidelines`).
  // Width matches the platform embedding model (AiKnowledgeChunk.embedding). Raw-SQL
  // read/write only — see the drift warning above.
  embedding            Unsupported("vector(1536)")?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  section       AppQuestionnaireSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  tags          AppQuestionSlotTag[]
  answers       AppAnswerSlot[]
  dataSlotLinks AppDataSlotQuestion[]

  @@unique([versionId, key])
  @@index([versionId])
  @@index([sectionId])
  @@map("app_question_slot")
}

/// A tag in a version's vocabulary (F2.2). Version-scoped — the vocabulary forks
/// with the version. `normalizedLabel` (trim+lowercase of `label`) is the
/// case-insensitive dedup key; `color` is an optional UI/analytics swatch.
/// Assigned to questions via the AppQuestionSlotTag join. Consumed by P8 analytics
/// filtering and F4.1 adaptive selection.
model AppQuestionTag {
  id              String   @id @default(cuid())
  versionId       String
  label           String
  normalizedLabel String // trim+lowercase of label; case-insensitive uniqueness key
  color           String? // optional swatch from the TAG_COLORS allowlist (types.ts)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  slots   AppQuestionSlotTag[]

  @@unique([versionId, normalizedLabel])
  @@index([versionId])
  @@map("app_question_tag")
}

/// M:N assignment of a vocabulary tag to a question (F2.2). Both sides cascade.
/// Application-layer validation (not a DB constraint) enforces that the tag and
/// slot belong to the same version — `AppQuestionSlot.versionId` is denormalised
/// for exactly this check.
model AppQuestionSlotTag {
  id             String   @id @default(cuid())
  questionSlotId String
  tagId          String
  createdAt      DateTime @default(now())

  questionSlot AppQuestionSlot @relation(fields: [questionSlotId], references: [id], onDelete: Cascade)
  tag          AppQuestionTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([questionSlotId, tagId])
  @@index([questionSlotId])
  @@index([tagId])
  @@map("app_question_slot_tag")
}

/// The revertible audit trail of every editorial decision the extractor made,
/// LLM-self-reported at extraction time. F2.3 lists these and restores `beforeJson`
/// on revert. Write path supports the full vocabulary; F1.1 EMITS the editorial +
/// inference set (prune, correct, rewrite_prompt, infer_type, merge_questions,
/// split_question, add_section, augment_question, infer_goal, infer_audience).
model AppQuestionnaireExtractionChange {
  id               String    @id @default(cuid())
  versionId        String
  changeType       String // see vocabulary note in ingestion docs
  targetEntityType String // section | question | version
  targetEntityId   String? // null for pruned-never-persisted / version-level
  sourceQuote      String? // the span in the source document
  beforeJson       Json? // pre-change state; restored on revert (null for creations)
  afterJson        Json? // post-change state (null for prune_*)
  rationale        String?
  confidence       Float?
  status           String    @default("applied") // applied | reverted
  revertedAt       DateTime? // set in F2.3
  revertedByUserId String? // plain String, no FK (UG-1); set in F2.3
  createdAt        DateTime  @default(now())

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId, status])
  @@index([changeType])
  @@map("app_questionnaire_extraction_change")
}

/// The uploaded source doc — supports SHA-256 dedup (F2.4 re-ingest) and parse
/// provenance / source-quote verification. NO User FK (UG-1).
model AppQuestionnaireSourceDocument {
  id            String   @id @default(cuid())
  versionId     String
  fileName      String
  fileHash      String // sha256 of the raw bytes
  byteSize      Int
  mimeType      String?
  pageCount     Int?
  warnings      Json? // parsed.warnings[]
  extractedText String   @db.Text // what extraction consumed; F2.3 verifies source quotes against it
  bytes         Bytes? // OPTIONAL raw upload, for F2.4 diff-against-source/re-parse with new opts
  createdAt     DateTime @default(now())

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@index([fileHash])
  @@map("app_questionnaire_source_document")
}

/// DEMO-ONLY (F2.5.1): demo-tenancy attribution + branding partition, NOT a
/// security boundary. Lets a questionnaire be labelled as a given prospect's demo
/// so the sales surface is attributable. Application-layer scoping on
/// single-tenant Sunrise — demo clients aren't adversarial, so hard isolation is
/// out of scope. A multi-customer fork activates Sunrise's RLS seam
/// (`TENANCY_MODE=multi`, `Org`/`orgId` at `lib/db/client.ts`) rather than
/// hardening this table.
///
/// FORK-GUIDANCE: see .context/app/questionnaire/forking.md § "Replacing demo
/// tenancy" — delete entirely (single-tenant prod) · rename to AppTenant + RLS
/// (multi-tenant prod) · keep as AppBrand without the marker.
///
/// IDENTITY + THEME. F2.5.1 landed identity only; F3.4 adds the theme columns now
/// that they have their first renderer (the invitation email; the F7.1 user UI is
/// the second). All theme columns are NULLABLE — `resolveTheme()`
/// (lib/app/questionnaire/theming) fills nulls with Sunrise defaults, so an
/// unthemed client renders exactly as before. The reset-sessions and
/// clone-for-client utilities still land in F6.4 / P3+. No User FK (UG-1) — a
/// global admin-managed fixture table, ownership implicit.
model AppDemoClient {
  id          String  @id @default(cuid())
  slug        String  @unique // URL-safe ("acme-bank"); admin URLs + later invite links
  name        String // display name ("Acme Bank Demo")
  description String? // internal admin note ("Prepared for the Q1 2026 pitch")
  isActive    Boolean @default(true) // soft-disable without delete

  // DEMO-ONLY (F3.4): theme columns. All nullable — null means "use the Sunrise
  // default" (resolveTheme fills it). The invitation email reads all four (ctaColor =
  // button, accentColor = fallback-link colour, logoUrl = header image, welcomeCopy =
  // intro line); accentColor is ALSO the F7.1 CSS accent variable.
  ctaColor    String? // CTA / primary button colour (hex, e.g. "#5469d4")
  accentColor String? // secondary accent colour (hex); email fallback-link colour + F7.1 CSS var
  logoUrl     String? // absolute https URL of the client logo shown in the email header
  welcomeCopy String? // branded intro line for the invitation email body

  // DEMO-ONLY (F7.1+): richer brand chrome for the respondent session. All optional —
  // each null/false leaves the surface looking as it did before. These let a brand be
  // *suggested* (a deep "surface" header band, a gradient CTA, a coloured backdrop the
  // logo was designed to sit on) while staying generic — any client can arrange them
  // differently. Resolved by resolveTheme(); see lib/app/questionnaire/theming.
  surfaceColor          String?  // deep brand "chrome" colour (hex); session header band + default logo backdrop
  ctaColorEnd           String?  // optional CTA gradient end colour (hex); set → CTA renders ctaColor→ctaColorEnd, null → solid ctaColor
  logoBackgroundColor   String?  // colour painted behind the logo (hex); null falls back to surfaceColor when the backdrop is enabled
  logoBackgroundEnabled Boolean  @default(false) // "apply this colour as the logo background" — the admin toggle

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Reverse relation (F2.5.1 AD2): the list endpoint counts attributed
  // questionnaires per client and the DELETE 409-guard reads it directly.
  questionnaires AppQuestionnaire[]
  // DEMO-ONLY (F3.4): invitations carrying this client's brand snapshot. SetNull on
  // delete (see AppQuestionnaireInvitation); the 409-guard counts questionnaires, not
  // these, so deleting a client clears its sent invitations' brand to the default.
  invitations    AppQuestionnaireInvitation[]

  @@map("app_demo_client")
}

/// A respondent's run over one launched version — the minimal slice of F4.6's
/// session machinery that F4.4 introduces to anchor persisted answers. The full
/// session/turn lifecycle (turn tables, profile snapshot, resumption) lands in
/// F4.6; this carries only what answer rows need: which version, a status, and an
/// optional respondent.
///
/// `isPreview` distinguishes a session created by the admin refine-answer route
/// (which exercises the write path before real respondent sessions exist) from a
/// genuine respondent run, so P8 analytics can exclude preview rows. The route
/// reuses one preview session per version (idempotent), so admins don't accrete
/// throwaway sessions.
///
/// `respondentUserId` is a plain String, no @relation (UG-1, as on
/// AppQuestionnaireInvitation); null until F4.6 binds real respondent sessions.
model AppQuestionnaireSession {
  id               String   @id @default(cuid())
  versionId        String
  status           String   @default("active") // SESSION_STATUSES (types.ts): active | paused | completed | abandoned | aborted
  isPreview        Boolean  @default(false) // true = admin refine-answer exercise, not a respondent run
  respondentUserId String? // respondent User.id; plain String, no FK (UG-1); set in F4.6
  // Invitations: the invitation this session was booted from (frictionless token flow), or null
  // for a walk-up/public/authenticated-direct session. Plain String, no @relation (UG-1) — and
  // deliberately so: it must NEVER become a graph edge that joins identity to answer content. Read
  // ONLY for per-invitee STATUS (started/completed); under anonymousMode, never to attribute answers
  // (the completion-tracking-only invariant — see invitations/linkage.ts).
  invitationId     String?
  // Seriousness / abuse gate: cumulative count of non-genuine answers flagged this session.
  // The route increments it; at `config.abuseThreshold` the session is abandoned.
  abuseStrikes     Int      @default(0)
  // Sensitivity awareness / safeguarding: the session's running-max disclosure severity
  // (null until first detection; "low" | "medium" | "high" — SENSITIVITY_SEVERITIES) and an
  // append-only array of remembered disclosures (SensitivityNote[]). The summaries are threaded
  // into the phraser so every later question stays gentle. Carries careful, non-graphic summaries
  // only; never surfaced raw to analytics or event metadata.
  sensitivityLevel String?
  sensitivityNotes Json     @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  version         AppQuestionnaireVersion        @relation(fields: [versionId], references: [id], onDelete: Cascade)
  answers         AppAnswerSlot[]
  dataSlotFills   AppDataSlotFill[]
  events          AppQuestionnaireSessionEvent[]
  turns           AppQuestionnaireTurn[]
  profileSnapshot AppRespondentProfileSnapshot?

  @@index([versionId])
  @@index([versionId, isPreview])
  @@index([invitationId])
  // DRIFT WARNING: a raw-SQL PARTIAL UNIQUE INDEX
  // (idx_app_questionnaire_session_preview_per_version, migration
  // 20260605141500) enforces at most one preview session per version
  // (WHERE "isPreview" = true) — Prisma can't model partial uniques, so it's
  // invisible here and a `migrate dev` schema-diff would emit a phantom DROP.
  // A drift probe in lib/app/db-drift.ts guards it; getOrCreatePreviewSession
  // (F4.5) depends on it for race-safety. Author future migrations on this
  // table with `--create-only` and strip any DROP of that index.
  @@map("app_questionnaire_session")
}

/// The profile-field values a respondent supplied at session start (F8.3), 1:1 with a
/// NON-anonymous session. PII by construction: `values` holds the answers to the
/// admin-authored `AppQuestionnaireConfig.profileFields` (name/email/role/custom),
/// keyed by field `key`.
///
/// ⚠️ ANONYMOUS-MODE INVARIANT ⚠️
/// NO row is ever written for a session whose version config has
/// `anonymousMode = true`. The capture seam (`questionnaire-sessions/_lib/create.ts`)
/// skips the write entirely in anonymous mode — absence, not an empty row (the
/// strongest, most testable guarantee). Read paths additionally omit the snapshot when
/// anonymous, as defence in depth. See `.context/app/questionnaire/anonymous-mode.md`.
///
/// This is the FIRST questionnaire model with a modelled `User` FK — the deferred-UG-1
/// "plain String, no @relation" posture used elsewhere is deliberately broken here
/// because this row IS personal data and MUST cascade on erasure. `respondentUserId`
/// is denormalised from the session so the cascade has a direct FK; it carries
/// `onDelete: Cascade` so `prisma.user.delete()` (via `eraseUser()`) removes the
/// snapshot natively — no erasure hook needed. The `session` FK also cascades, so
/// deleting a session removes its snapshot.
model AppRespondentProfileSnapshot {
  id               String   @id @default(cuid())
  sessionId        String   @unique
  respondentUserId String? // denormalised from the session; null for no-login (which never writes a row anyway)
  values           Json     @default("{}") // { [profileFieldKey]: string | number } — the collected PII
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session AppQuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?                   @relation(fields: [respondentUserId], references: [id], onDelete: Cascade)

  @@index([respondentUserId])
  @@map("app_respondent_profile_snapshot")
}

/// One captured answer for a question slot within a session. F4.2 produces the
/// extraction INTENTS; F4.4 is the first writer (via the refine-answer route) and
/// owns the refinement update: the value/provenance change plus an appended
/// `refinementHistory` entry. F4.6 wires the live per-turn write path on top of the
/// same model.
///
/// `provenanceLabel` is a plain String validated against ANSWER_PROVENANCES at the
/// boundary (house style — `selectionStrategy`/`contradictionMode` are columns, not
/// Prisma enums), so adding a label is a tuple edit, not a migration. A `refine`
/// transitions it to `refined`; an `overwrite` preserves it.
///
/// `confidence` is a Float 0–1 (matching AppQuestionSlot.extractionConfidence), NOT
/// the Int(1–10) an early spec sketched. `refinementHistory` is a JSON array of
/// RefinementHistoryEntry (refinement/types.ts), default []. `provenanceItems` holds
/// Sunrise's ProvenanceItem[] contract for PII/cost; F4.4 does not populate it.
model AppAnswerSlot {
  id                String   @id @default(cuid())
  sessionId         String
  questionSlotId    String
  value             Json
  confidence        Float? // 0–1; null when not scored
  provenanceLabel   String   @default("direct") // ANSWER_PROVENANCES (types.ts)
  provenanceItems   Json? // Sunrise ProvenanceItem[]; reserved, not populated by F4.4
  rationale         String?
  lastUpdatedTurnId String? // F4.6 turn-loop seam; null until the live loop exists
  refinementHistory Json     @default("[]") // RefinementHistoryEntry[] (refinement/types.ts)
  // Presentation mode (P-presentation): true when the respondent set/edited this answer
  // themselves in form view. Authoritative — the per-turn extraction/refinement pipeline
  // must NOT silently overwrite a respondent-edited answer (it may still flag a
  // contradiction). The "manual" refinement-history source records the edit; this flag is
  // the cheap guard the pipeline checks.
  respondentEdited  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  session      AppQuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionSlot AppQuestionSlot         @relation(fields: [questionSlotId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionSlotId]) // one answer per slot per session — the upsert key
  @@index([sessionId])
  @@index([questionSlotId])
  @@map("app_answer_slot")
}

/// A semantic DATA SLOT — the abstraction layer over questions (Data Slots feature).
///
/// A data slot is a short (1–4 word) `name` plus a `description` explaining what it
/// captures and why it matters. It is the respondent-facing operational target: the
/// live conversation aims to FILL data slots naturally, while the underlying questions
/// (AppQuestionSlot/AppAnswerSlot) are answered in the background as the deliverable.
/// Version-scoped (forks with the version, like tags F2.2); generated by the data-slot
/// generator agent after questions are approved, then admin-reviewed.
///
/// `theme` is a short group label the generator assigns (the respondent panel groups by
/// it). `ordinal` orders slots within the version; `weight` feeds weighted/topic-local
/// targeting (mirrors AppQuestionSlot.weight). `generationConfidence` is the generator's
/// 0–1 confidence. A slot relates to one or more questions via AppDataSlotQuestion (M:N) —
/// filling the slot well captures those questions.
model AppDataSlot {
  id                   String   @id @default(cuid())
  versionId            String
  key                  String // slug, unique per version (fills/links reference it, not the cuid)
  name                 String // 1–4 words (the panel label + the targeting "prompt")
  description          String // why it matters + what counts as filled (the targeting "guidelines")
  theme                String // short group label for panel grouping
  ordinal              Int      @default(0)
  weight               Float    @default(1.0)
  generationConfidence Float? // 0–1, set by the generator
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  version   AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  questions AppDataSlotQuestion[]
  fills     AppDataSlotFill[]

  @@unique([versionId, key])
  @@index([versionId])
  @@map("app_data_slot")
}

/// A PENDING data-slot generation for a version — the reviewable DRAFT proposal (Data Slots
/// feature). Generating data slots runs a paid LLM call; rather than holding the result only
/// in the admin's browser (lost on navigation), the proposal is persisted here as a JSON
/// snapshot of `GeneratedDataSlot[]`. It is explicitly NOT live: runtime targeting, the
/// respondent panel, and the launch gate read only AppDataSlot (the saved/live set), never
/// this table. Saving the reviewed set (PUT data-slots) writes AppDataSlot and clears this
/// draft in one transaction; "Discard draft" deletes it. One pending draft per version
/// (`versionId @unique`); cascades/forks with the version.
model AppDataSlotDraft {
  id        String   @id @default(cuid())
  versionId String   @unique
  slots     Json // GeneratedDataSlot[] snapshot — the proposed, reviewable set (not live)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  version AppQuestionnaireVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@map("app_data_slot_draft")
}

/// M:N mapping of a data slot to the question(s) it abstracts over. Both sides cascade.
/// A data slot "meaningfully captures" its mapped questions: filling the slot in the
/// conversation lets the background extractor answer those questions.
model AppDataSlotQuestion {
  id             String   @id @default(cuid())
  dataSlotId     String
  questionSlotId String
  createdAt      DateTime @default(now())

  dataSlot     AppDataSlot     @relation(fields: [dataSlotId], references: [id], onDelete: Cascade)
  questionSlot AppQuestionSlot @relation(fields: [questionSlotId], references: [id], onDelete: Cascade)

  @@unique([dataSlotId, questionSlotId])
  @@index([dataSlotId])
  @@index([questionSlotId])
  @@map("app_data_slot_question")
}

/// One filled data slot within a session — the respondent-facing capture (Data Slots
/// feature). Mirrors AppAnswerSlot but for the abstraction layer: `value` is the captured
/// structured position, `paraphrase` is a short natural-language restatement of the
/// respondent's position toward the slot (shown in the panel), `confidence` is how well
/// the agent believes it understands their position. Per session, one fill per slot.
///
/// PII by construction (the paraphrase + value are the respondent's words). Cascades from
/// the session (deleting/resetting a session removes its fills — F6.4 reset + erasure rely
/// on this cascade, no explicit table list needed).
model AppDataSlotFill {
  id                String   @id @default(cuid())
  sessionId         String
  dataSlotId        String
  value             Json
  paraphrase        String? // short restatement of the respondent's position (panel-facing)
  confidence        Float? // 0–1; the agent's confidence in its understanding
  provenanceLabel   String   @default("direct") // ANSWER_PROVENANCES (types.ts)
  rationale         String?
  provisional       Boolean  @default(false) // best-effort inference recorded after the re-ask cap; shown "provisional · may revisit". Cleared by a later confident fill.
  lastUpdatedTurnId String?
  refinementHistory Json     @default("[]") // RefinementHistoryEntry[] (refinement/types.ts)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  session  AppQuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  dataSlot AppDataSlot             @relation(fields: [dataSlotId], references: [id], onDelete: Cascade)

  @@unique([sessionId, dataSlotId]) // one fill per slot per session — the upsert key
  @@index([sessionId])
  @@index([dataSlotId])
  @@map("app_data_slot_fill")
}

/// The append-only audit trail of a session's lifecycle (F4.6). One row per recorded
/// event: the four status transitions (`paused`, `resumed`, `completed`, `abandoned`),
/// an optional `created` marker, and `cost_cap_reached` — a non-transition event the
/// budget hook (F6.3/F6.5) fires, wired here but not fired in F4.6. `eventType` is a
/// plain String validated against SESSION_EVENT_TYPES (session/types.ts) at the seam
/// (house style — like `status`/`provenanceLabel`), so adding an event is a tuple edit.
///
/// `fromStatus`/`toStatus` capture the transition (both null for `cost_cap_reached`,
/// `fromStatus` null for `created`); `metadata` carries event-specific detail (e.g.
/// `{ spentUsd, capUsd }` for a cost-cap event). Fully Prisma-modelled — no raw-SQL
/// object here, so (unlike the session's partial unique index) no drift probe is needed.
model AppQuestionnaireSessionEvent {
  id         String   @id @default(cuid())
  sessionId  String
  eventType  String // SESSION_EVENT_TYPES (session/types.ts)
  fromStatus String? // null for created / cost_cap_reached
  toStatus   String? // null for cost_cap_reached
  reason     String? // optional human-readable note (e.g. why abandoned)
  metadata   Json? // event-specific detail; e.g. { spentUsd, capUsd } for cost_cap_reached
  createdAt  DateTime @default(now())

  session AppQuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
  @@map("app_questionnaire_session_event")
}

/// One persisted respondent turn over a live session (F6.1). The streaming turn
/// route's seam (`_lib/turns.ts`) writes one row AFTER the deterministic per-turn
/// orchestrator pipeline runs (extract → detect → refine → assess → offer → select).
/// It anchors the answer rows the turn produced — `AppAnswerSlot.lastUpdatedTurnId`
/// points back here, finally fired by `recordTurn` (null until F6.1) — and captures
/// per-turn cost plus which capabilities ran.
///
/// `targetedQuestionId` is a plain String validated at the seam (not an FK) — symmetry
/// with the JSON `sideEffectAnswerIds` id array and the UG-1 house style, avoiding a
/// second slot-prune `onDelete` policy. `toolCalls` (the ordered capability outcomes —
/// `{ slug, success, code?, latencyMs? }`) and `sideEffectAnswerIds` (the AppAnswerSlot
/// ids this turn created/updated) are JSON arrays read wholesale, like the answer's
/// `refinementHistory`. `warnings` (`{ code, message }[]`) are the side-band notices the
/// turn surfaced (seriousness / support / contradiction) — persisted so the respondent
/// surface can replay them inline beneath the turn on resume, not just in the moment.
/// `costUsd` is the summed per-turn LLM spend; null until set.
/// `ordinal` is the 1-based turn index, derived `count+1` inside the write transaction
/// (no `@@unique([sessionId, ordinal])` — a unique can throw under a retried turn; rare
/// gaps are acceptable). No `respondentUserId` here — it's reachable via the session.
model AppQuestionnaireTurn {
  id                    String   @id @default(cuid())
  sessionId             String
  ordinal               Int // 1-based turn index within the session
  userMessage           String   @db.Text // respondent's message (PII)
  agentResponse         String   @db.Text // composed agent reply streamed back
  targetedQuestionId    String? // AppQuestionSlot.id asked for; null = completion/offer turn
  targetedDataSlotId    String? // AppDataSlot.id targeted this turn (data-slot mode); null otherwise — drives the per-slot re-ask/park counter
  toolCalls             Json     @default("[]") // [{ slug, success, code?, latencyMs? }] ordered
  sideEffectAnswerIds   Json     @default("[]") // AppAnswerSlot.id[] this turn created/updated
  sideEffectDataSlotIds Json     @default("[]") // AppDataSlotFill.id[] this turn created/updated (data-slot mode)
  warnings              Json     @default("[]") // [{ code, message }] side-band notices shown beneath this turn (seriousness/support/contradiction) — replayed inline on resume
  reasoning             Json     @default("[]") // ReasoningStep[] — live "watch it think" trace, persisted (when config.reasoningStreamPersist) so it replays on resume/scroll-back. Respondent-safe (no abuse/sensitivity). (lib/.../reasoning)
  costUsd               Float? // summed per-turn LLM spend; null until set
  createdAt             DateTime @default(now())

  session AppQuestionnaireSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, ordinal])
  @@map("app_questionnaire_turn")
}

/// One persisted design-time evaluation run over a version's authored structure (F5.2).
///
/// The synchronous POST route dispatches the seven judges (the F5.1 dispatch seam — one
/// structured LLM call per dimension, fail-soft per judge), then writes this header plus
/// one `AppQuestionnaireEvaluationFinding` per judge finding in a single transaction. The
/// run is terminal the moment the POST returns — there is no worker and no polling (the
/// 2026-06-05 decision: app-native dispatch, not Sunrise's `AiEvaluationRun` worker).
///
/// `status` is a plain String (house style — like `AppQuestionnaireVersion.status`) holding
/// a terminal value: `completed` (every judge returned a verdict), `partial` (some judges
/// returned a diagnostic), or `failed` (no judge returned). It stays a String so a future
/// async worker could add `running`/`queued` without a migration. Per-dimension verdict
/// scores + diagnostics live in `dimensionSummary` JSON — a fixed ≤7-entry array the list
/// and detail UI read in one shot (the `audience`/`refinementHistory` JSON precedent), so it
/// needs no per-dimension table. `triggeredByUserId` is the admin who ran it: plain String,
/// no `@relation` (the UG-1 deferred-User-FK posture, as elsewhere in this schema).
///
/// `questionnaireId` is denormalised from the version (the `AppQuestionSlot.versionId`
/// precedent) so questionnaire-scoped admin views can index without joining through the
/// version. Fully Prisma-modelled — no raw-SQL object — so no drift probe is needed.
model AppQuestionnaireEvaluationRun {
  id                  String    @id @default(cuid())
  versionId           String
  questionnaireId     String // denormalised parent for cheap questionnaire-scoped listing
  status              String    @default("completed") // completed | partial | failed (terminal in F5.2)
  triggeredByUserId   String? // admin User.id; plain String, no FK (UG-1)
  dimensionsRequested Int
  dimensionsRun       Int // judges that returned a verdict
  dimensionsFailed    Int // judges that returned a diagnostic
  totalFindings       Int       @default(0)
  dimensionSummary    Json // [{ dimension, score?, findingCount, diagnostic? }] — read wholesale by the UI
  // The `VersionStructureInput` the judges read, captured at run time (F5.3). The review
  // queue diffs the targeted slice of this against the live structure to derive a finding
  // `stale` at READ time (never stored) — so a finding only flags stale when the specific
  // thing it addresses actually changed. Nullable: F5.2 rows predate the snapshot; a null
  // snapshot means staleness can't be derived (treated as not-stale, best-effort).
  structureSnapshot   Json?
  costUsd             Float? // reserved; populated if/when the dispatcher surfaces per-run cost
  error               String? // run-level note when status = 'failed'
  startedAt           DateTime
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  version  AppQuestionnaireVersion             @relation(fields: [versionId], references: [id], onDelete: Cascade)
  findings AppQuestionnaireEvaluationFinding[]

  @@index([versionId, createdAt]) // newest-first list per version (the primary query)
  @@index([questionnaireId])
  @@index([status])
  @@map("app_questionnaire_evaluation_run")
}

/// One actionable finding from one judge in one run (F5.2).
///
/// Row-per-finding (NOT a JSON blob on the run) because F5.3's review queue mutates findings
/// individually — accept / decline / edit / apply, plus stale derivation — and queries /
/// filters / paginates them; that access pattern wants rows. F5.2 persisted the `JudgeFinding`
/// prose contract (evaluation/types.ts) plus the stamping `dimension`, an `ordinal` for
/// stable presentation order within (run, dimension), and a `status`. F5.3 adds the structured
/// edit + review-decision columns below.
///
/// `proposedEdit` is the judge's optional machine-applicable op (`ProposedEdit`, validated /
/// soft-degraded by `coerceProposedEdit` on persist); `editedOverride` is the admin's edited
/// op, which takes precedence at apply. The decision/apply columns record who/when. `status`
/// holds `pending | accepted | declined | applied` — `stale` is **derived at read time** from
/// the run's `structureSnapshot` vs the live structure, never written (it would rot the instant
/// the structure changes). `appliedToVersionId` is a plain String (may point at a forked draft;
/// the UG-1 deferred-FK posture, like `triggeredByUserId`). `status`/`severity`/`dimension` are
/// plain Strings validated at the seam (house style). Fully Prisma-modelled — no drift probe.
model AppQuestionnaireEvaluationFinding {
  id                 String    @id @default(cuid())
  runId              String
  dimension          String // EvaluationDimension (evaluation/types.ts), stamped by the caller
  ordinal            Int // presentation order within (run, dimension)
  targetKey          String // slot `key` | section:<title> | goal | audience
  severity           String // FINDING_SEVERITIES: info | minor | major
  proposedChange     String
  rationale          String
  sourceQuote        String? // offending text when the finding points at one
  proposedEdit       Json? // optional structured op (ProposedEdit); null when prose-only or degraded (F5.3)
  editedOverride     Json? // admin-edited op; takes precedence over proposedEdit at apply (F5.3)
  status             String    @default("pending") // pending | accepted | declined | applied (stale is derived, not stored)
  decidedByUserId    String? // admin who accepted/declined/edited; plain String, no FK (UG-1)
  decidedAt          DateTime?
  appliedAt          DateTime?
  appliedToVersionId String? // version actually written (may be a forked draft); plain String (UG-1)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  run AppQuestionnaireEvaluationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([runId, dimension])
  @@index([status])
  @@map("app_questionnaire_evaluation_finding")
}
